# App
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/open_agent?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Encryption (for API keys)
ENCRYPTION_SECRET=your-32-character-encryption-secret

# Boxlite (to be configured on KVM host)
BOXLITE_API_URL=http://localhost:8080
BOXLITE_API_TOKEN=

# Redis (for queue/websocket - optional for MVP)
REDIS_URL=redis://localhost:6379
